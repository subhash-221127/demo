# ─── CityFix Backend — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git

MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/complaint-management-system?retryWrites=true&w=majority

# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_strong_random_secret_here

GEMINI_API_KEY=your_gemini_api_key

# Frontend URL (for CORS) — your actual Render URL after deploy
CLIENT_URL=https://your-app-name.onrender.com

EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
